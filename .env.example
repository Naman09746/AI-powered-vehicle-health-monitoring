# ──────────────────────────────────────────────
# Vehicle Health Monitor — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database
# PostgreSQL (dev with docker-compose): postgresql+asyncpg://vhm:vhm_secret@localhost:5432/vehicle_health
# SQLite (fallback):   sqlite:///vehicle_health.db
DATABASE_URL=postgresql+asyncpg://vhm:vhm_secret@localhost:5432/vehicle_health

# Secret key for session signing and encryption
SECRET_KEY=change-me-to-a-random-64-char-string

# Environment (development | production)
ENV=development

# Logging level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Max upload file size in MB
MAX_UPLOAD_SIZE_MB=200

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# ──────────────────────────────────────────────
# SMTP / Email Alerts (optional)
# ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=Vehicle Health Monitor <alerts@yourdomain.com>

# ──────────────────────────────────────────────
# Redis (Celery + caching + token blocklist)
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────
# Read Replica Database (optional — for dashboard queries)
# ──────────────────────────────────────────────
# DATABASE_URL_READ_ONLY=postgresql+asyncpg://vhm_ro:vhm_ro_secret@replica-host:5432/vehicle_health

# ──────────────────────────────────────────────
# Keycloak / OAuth2 (optional)
# ──────────────────────────────────────────────
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=vehicle-health
# KEYCLOAK_CLIENT_ID=vhm-api
# KEYCLOAK_CLIENT_SECRET=
# OAUTH_ENABLED=false

# ──────────────────────────────────────────────
# Twilio SMS (optional — escalation alerts)
# ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ──────────────────────────────────────────────
# Web Push / VAPID (optional — browser notifications)
# ──────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=alerts@yourdomain.com
